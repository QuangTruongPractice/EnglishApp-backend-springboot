    }

    class UserVideoProgress {
        +Integer id
        +String userId
        +Video video
        +Integer watchedDuration
        +Double progressPercentage
        +Integer lastPosition
        +Boolean isCompleted
        +LocalDateTime updatedAt
    }

    class UserQuizProgress {
        +Integer id
        +String userId
        +Quiz quiz
        +Integer count
        +LocalDateTime updatedAt
    }

    MainTopic "1" -- "*" SubTopic : contains
    SubTopic "*" -- "*" Vocabulary : categorized_in
    Vocabulary "1" -- "*" VocabularyMeaning : defines
    Vocabulary "1" -- "*" WordImage : illustrates
    VocabularyMeaning "1" -- "*" MeaningSynonym : has_synonym
    Video "1" -- "*" Subtitles : has
    Quiz "1" -- "*" Answer : has_options
    UserVocabularyProgress "*" -- "1" Vocabulary : tracks
    UserVideoProgress "*" -- "1" Video : tracks
    UserQuizProgress "*" -- "1" Quiz : tracks
