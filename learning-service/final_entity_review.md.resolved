        +LocalDateTime createdAt
    }

    class Quiz {
        +Integer id
        +QuizType type
        +String question
        +String text
        +List~Answer~ answers
        +LocalDateTime createdAt
    }

    class Answer {
        +Integer id
        +Quiz quiz
        +String answer
        +Boolean isCorrect
        +LocalDateTime createdAt
    }

    class UserVocabularyProgress {
        +Integer id
