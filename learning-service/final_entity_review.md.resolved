        +VocabularyMeaning synonymMeaning
    }

    class WordImage {
        +Integer id
        +Vocabulary vocabulary
        +String url
    }

    class WordType {
        +Integer id
        +Type type
    }

    class Video {
        +Integer id
        +String videoId
        +String title
        +String youtubeUrl
        +Integer duration
